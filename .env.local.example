# Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-only, never exposed to the browser. Used for
# admin writes and analytics aggregation.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Single allow-listed admin email (must match a Supabase Auth user you create)
ADMIN_EMAIL=you@example.com

# Salt used to hash IP+UA for anonymous analytics — any random string
ANALYTICS_SALT=change-me-to-a-random-string

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BATTLE_SERIES_URL=https://web3-battle-series.vercel.app/
